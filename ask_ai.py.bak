import os
import subprocess
from datetime import datetime
import httpx
from dotenv import load_dotenv

load_dotenv()

BASE = os.path.expanduser("~/.areal-neva-core")

RULES = os.path.join(BASE, "GLOBAL_INSTRUCTIONS.md")
CONTEXT = os.path.join(BASE, "sync_context.md")
HISTORY = os.path.join(BASE, "history.md")
PROFILE_FILE = os.path.join(BASE, "ai/profiles/ACTIVE_PROFILE.txt")
PROFILES_DIR = os.path.join(BASE, "ai/profiles")

OPENAI_API_KEY = os.getenv("OPENAI_API_KEY", "")


def read_file(path: str) -> str:
    if not os.path.exists(path):
        return ""
    with open(path, "r", encoding="utf-8") as f:
        return f.read().strip()


def get_active_profile_path() -> str:
    active_profile = read_file(PROFILE_FILE)
    if not active_profile:
        raise FileNotFoundError("ACTIVE_PROFILE.txt пустой или отсутствует")
    profile_path = os.path.join(PROFILES_DIR, f"{active_profile}.txt")
    if not os.path.exists(profile_path):
        raise FileNotFoundError(f"Профиль не найден: {profile_path}")
    return profile_path


def build_full_prompt(user_prompt: str) -> str:
    rules = read_file(RULES)
    context = read_file(CONTEXT)
    profile = read_file(get_active_profile_path())

    return "\n\n".join(
        [
            "SYSTEM RULES:\n" + rules,
            "ACTIVE PROFILE:\n" + profile,
            "SYNC CONTEXT:\n" + context,
            "USER REQUEST:\n" + user_prompt,
        ]
    )


def call_openai(prompt: str) -> str:
    if not OPENAI_API_KEY:
        raise RuntimeError("OPENAI_API_KEY не найден в .env")

    headers = {
        "Authorization": f"Bearer {OPENAI_API_KEY}",
        "Content-Type": "application/json",
    }

    payload = {
        "model": "gpt-4o-mini",
        "messages": [
            {
                "role": "user",
                "content": prompt,
            }
        ],
        "temperature": 0.2,
    }

    response = httpx.post(
        "https://api.openai.com/v1/chat/completions",
        headers=headers,
        json=payload,
        timeout=120,
    )

    response.raise_for_status()
    data = response.json()

    return data["choices"][0]["message"]["content"].strip()


def append_history(user_prompt: str, answer: str) -> None:
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    with open(HISTORY, "a", encoding="utf-8") as f:
        f.write("\n\n")
        f.write(f"## {timestamp}\n")
        f.write("PROMPT:\n")
        f.write(user_prompt + "\n\n")
        f.write("ANSWER:\n")
        f.write(answer + "\n")


def git_sync() -> None:
    subprocess.run(["git", "add", "-A"], cwd=BASE, check=False)
    subprocess.run(
        ["git", "commit", "-m", "auto: update history and context"],
        cwd=BASE,
        check=False,
    )
    subprocess.run(["git", "push"], cwd=BASE, check=False)


def main() -> None:
    user_prompt = input("ASK > ").strip()

    if not user_prompt:
        print("Пустой запрос")
        return

    full_prompt = build_full_prompt(user_prompt)
    answer = call_openai(full_prompt)

    print("\nANSWER:\n")
    print(answer)

    append_history(user_prompt, answer)
    git_sync()


if __name__ == "__main__":
    main()

import os
import subprocess
from datetime import datetime

BASE = os.path.expanduser("~/.areal-neva-core")

RULES = f"{BASE}/GLOBAL_INSTRUCTIONS.md"
CONTEXT = f"{BASE}/sync_context.md"
HISTORY = f"{BASE}/history.md"
PROFILE_FILE = f"{BASE}/ai/profiles/ACTIVE_PROFILE.txt"
PROFILES_DIR = f"{BASE}/ai/profiles"

def read_file(path):
    if not os.path.exists(path):
        return ""
    with open(path, "r", encoding="utf-8") as f:
        return f.read()

def get_active_profile():
    name = read_file(PROFILE_FILE).strip()
    return f"{PROFILES_DIR}/{name}.txt"

def log_history(prompt, answer):
    with open(HISTORY, "a", encoding="utf-8") as f:
        f.write("\n\n")
        f.write(f"## {datetime.now()}\n")
        f.write("PROMPT:\n")
        f.write(prompt + "\n\n")
        f.write("ANSWER:\n")
        f.write(answer + "\n")

def git_sync():
    subprocess.run(["git", "add", "-A"], cwd=BASE)
    subprocess.run(["git", "commit", "-m", "auto: history update"], cwd=BASE)
    subprocess.run(["git", "push"], cwd=BASE)

def main():
    prompt = input("ASK > ")

    rules = read_file(RULES)
    context = read_file(CONTEXT)
    profile = read_file(get_active_profile())

    full_prompt = "\n".join([
        "SYSTEM RULES:",
        rules,
        "PROFILE:",
        profile,
        "CONTEXT:",
        context,
        "USER:",
        prompt
    ])

    print("\n--- SYSTEM PROMPT SENT ---\n")
    print(full_prompt[:1000])
    print("\n--- END ---\n")

    answer = "MODEL RESPONSE PLACEHOLDER"

    log_history(prompt, answer)
    git_sync()

if __name__ == "__main__":
    main()


